{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXT_POSTGRES_URL",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "AUTH_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "ANTHROPIC_API_KEY",
        "ENCRYPTION_KEY",
        "MAIL_FROM",
        "MAIL_PASSWORD",
        "NOTIFY_EMAIL",
        "RAZORPAY_KEY_ID",
        "RAZORPAY_KEY_SECRET",
        "RAZORPAY_WEBHOOK_SECRET",
        "GITHUB_MOBILE_CLIENT_ID",
        "GITHUB_MOBILE_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "SARVAM_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_POSTGRES_URL",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "AUTH_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "ANTHROPIC_API_KEY",
        "ENCRYPTION_KEY",
        "MAIL_FROM",
        "MAIL_PASSWORD",
        "NOTIFY_EMAIL",
        "RAZORPAY_KEY_ID",
        "RAZORPAY_KEY_SECRET",
        "RAZORPAY_WEBHOOK_SECRET",
        "GITHUB_MOBILE_CLIENT_ID",
        "GITHUB_MOBILE_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "SARVAM_API_KEY"
      ]
    },
    "lint": {
      "cache": false
    },
    "validate": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
