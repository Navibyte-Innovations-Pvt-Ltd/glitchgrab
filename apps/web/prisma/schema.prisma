generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NEXT_POSTGRES_URL")
  directUrl = env("NEXT_DIRECT_URL")
}

// ─── Pre-launch ──────────────────────────────────────────

model Waitlist {
  id          String   @id @default(cuid())
  email       String   @unique
  source      String?  @default("landing")
  priceFeel   String?
  topFeature  String?
  currentTool String?
  suggestion  String?
  createdAt   DateTime @default(now())
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  githubLogin    String?
  whatsappPhone  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  repos         Repo[]
  aiConfig      AiConfig?
  subscription  Subscription?
  webhooks      Webhook[]
  gscProperties       GscProperty[]
  gscConnectSessions  GscConnectSession[]
  ownedOrgs     Organization[]
  orgMemberships OrgMember[]
  glitchRecordTokens GlitchRecordToken[]
  aiEnhanceLogs      AiEnhanceLog[]
  whatsappOtps  WhatsappOtp[]
}

model WhatsappOtp {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core ────────────────────────────────────────────────

model Repo {
  id        String   @id @default(cuid())
  userId    String
  orgId     String?
  githubId  Int
  fullName  String
  owner     String
  name      String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  org               Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  tokens            ApiToken[]
  reports           Report[]
  issues            Issue[]
  gscProperties     GscProperty[]
  testerRepos       TesterRepo[]
  qaChecks          QaCheck[]

  @@unique([userId, githubId])
  @@index([githubId])
  @@index([orgId])
}

model ApiToken {
  id        String    @id @default(cuid())
  repoId    String
  tokenHash String    @unique
  name      String    @default("Default")
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  repo           Repo           @relation(fields: [repoId], references: [id], onDelete: Cascade)
  reports        Report[]
  aiEnhanceLogs  AiEnhanceLog[]
}

// ─── Reports & Issues ────────────────────────────────────

enum ReportSource {
  SDK_AUTO
  SDK_USER_REPORT
  DASHBOARD_UPLOAD
  HANDWRITTEN_NOTE
  MCP
}

enum ReportStatus {
  PENDING
  PROCESSING
  CREATED
  DUPLICATE
  FAILED
}

model Report {
  id                 String       @id @default(cuid())
  repoId             String
  tokenId            String?
  source             ReportSource
  status             ReportStatus @default(PENDING)
  rawInput           String?
  screenshot         String?
  errorStack         String?
  userAgent          String?
  pageUrl            String?
  /// Hash of errorMessage + pageUrl + top stack frame for dedup
  signature          String?
  metadata           Json?
  aiResponse         Json?
  failReason         String?
  /// Primary key of the reporter in the host app's database
  reporterPrimaryKey String
  reporterName       String
  reporterEmail      String?
  reporterPhone      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  repo  Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  token ApiToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  issue Issue?

  @@index([repoId, signature, createdAt])
}

model Issue {
  id           String   @id @default(cuid())
  reportId     String   @unique
  repoId       String
  githubNumber Int
  githubUrl    String
  title        String
  body         String
  labels       String[]
  severity     String?
  isDuplicate  Boolean  @default(false)
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)
}

// ─── Billing ─────────────────────────────────────────────

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  razorpaySubscriptionId String   @unique
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AI Config ───────────────────────────────────────────

enum AiProvider {
  PLATFORM
  OPENAI
  ANTHROPIC
}

model AiConfig {
  id              String     @id @default(cuid())
  userId          String     @unique
  provider        AiProvider @default(PLATFORM)
  encryptedApiKey String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Google Search Console ───────────────────────────

model GscProperty {
  id                    String    @id @default(cuid())
  userId                String
  siteUrl               String
  repoId                String?
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  indexedCount          Int       @default(0)
  notIndexedCount       Int       @default(0)
  lastSyncAt            DateTime?
  cachedNotIndexedPages   Json?
  seoHealthIssueUrl       String?
  seoHealthSnoozedUntil   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo Repo? @relation(fields: [repoId], references: [id], onDelete: SetNull)
  indexingSnapshots GscIndexingSnapshot[]

  @@unique([userId, siteUrl])
}

// ─── GSC Indexing Snapshot — historical record per sync/reindex ────────

model GscIndexingSnapshot {
  id              String   @id @default(cuid())
  propertyId      String
  // "sync" = full sitemap inspection; "reindex" = re-indexing submission
  kind            String
  // counts at time of snapshot
  indexedCount    Int      @default(0)
  notIndexedCount Int      @default(0)
  totalChecked    Int      @default(0)
  // For "reindex" entries: how many URLs we actually submitted to Google
  submittedCount  Int?
  createdAt       DateTime @default(now())

  property GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
}

// ─── GSC Connect Session (temporary, expires after 10 min) ────────────────

model GscConnectSession {
  id               String   @id @default(cuid())
  userId           String
  encryptedAccess  String
  encryptedRefresh String?
  tokenExpiresAt   DateTime
  sites            Json     // Array of {siteUrl: string, permissionLevel: string}
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Organizations ────────────────────────────────────

enum OrgRole {
  OWNER
  MEMBER
}

model Organization {
  id             String   @id @default(cuid())
  githubOrgLogin String   @unique
  githubOrgId    Int      @unique
  name           String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner   User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members OrgMember[]
  repos   Repo[]
  testers Tester[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

// ─── Webhooks ──────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth token for GlitchRecord desktop app
model GlitchRecordToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// AI enhance before/after log — for auditing whether AI is preserving user intent
model AiEnhanceLog {
  id           String   @id @default(cuid())
  originalText String
  enhancedText String
  changed      Boolean  // false = AI returned same text
  pageUrl      String?
  apiTokenId   String?  // set when called from SDK
  userId       String?  // set when called from dashboard session
  createdAt    DateTime @default(now())

  apiToken ApiToken? @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Temporary click-capture sessions for Recordly script generation
model CaptureSession {
  id         String   @id @default(cuid())
  events     Json
  meta       Json?    // RecordingMeta from Recordly — clips, cuts, duration
  script     String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// Persistent narration training/feedback telemetry. Unlike CaptureSession (which
// expires), this survives so we can analyze how much refinement scripts need and
// improve the model. One row per capture session; the generate route writes the
// initial row, the refine route appends each user refinement turn. Writes are
// best-effort — telemetry must NEVER break script generation.
model NarrationTelemetry {
  id          String   @id @default(cuid())
  sessionId   String   @unique // the CaptureSession id this generation came from

  // ── Input context ───────────────────────────────────────────────
  events      Json     // raw captured events, as-is (incl. typed previews)
  meta        Json?    // RecordingMeta (cuts/zooms/duration)
  appName     String?  // derived product name (deriveAppName)
  lang        String?
  gender      String?
  durationSec Int?
  eventCount  Int      @default(0)
  hasNotes    Boolean  @default(false) // any shift-mark "note" events present
  noteCount   Int      @default(0)
  noteAnswers Json?    // what the user said to explain at each marked spot

  // ── Initial generation ──────────────────────────────────────────
  model            String  // deepseek model used for generation
  genLatencyMs     Int     @default(0)
  initialScript    String  @default("")
  initialChars     Int     @default(0)
  wasEmpty         Boolean @default(false) // generation returned nothing
  wasRoman         Boolean @default(false) // lang=hi but came back Roman/Latin
  devanagariRetried Boolean @default(false) // the Devanagari-fix retry fired
  devanagariRatio  Float   @default(0)

  // ── Refinements (appended by the refine route) ──────────────────
  // refinements: [{ ts, userMessage, resultingScript, chars }] — full history of
  // what the user asked to change and the version it produced.
  refinements Json    @default("[]")
  refineCount Int     @default(0) // how many versions the user needed (quality proxy)
  finalScript String  @default("")
  finalChars  Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([appName])
  @@index([createdAt])
}

// ─── QA / Tester workflow ────────────────────────────────
// A tester (e.g. an external QA person) invited to verify that developer
// fixes actually work. May NOT be part of the GitHub org — accesses a
// magic-link QA page instead of logging in. Notified over WhatsApp.

model Tester {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  email       String?
  phone       String?  // WhatsApp number (digits, optional country code)
  /// Unguessable capability token — the /qa/<token> page is gated only by this
  magicToken  String   @unique
  invitedById String
  createdAt   DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repos  TesterRepo[]
  checks QaCheck[]
  otps   TesterOtp[]

  @@index([orgId])
}

model TesterOtp {
  id        String   @id @default(cuid())
  testerId  String
  phone     String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  tester Tester @relation(fields: [testerId], references: [id], onDelete: Cascade)

  @@index([testerId])
}

model TesterRepo {
  id        String   @id @default(cuid())
  testerId  String
  repoId    String
  createdAt DateTime @default(now())

  tester Tester @relation(fields: [testerId], references: [id], onDelete: Cascade)
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([testerId, repoId])
  @@index([repoId])
}

enum QaStatus {
  PENDING
  PASS
  FAIL
}

model QaCheck {
  id             String   @id @default(cuid())
  testerId       String
  repoId         String
  githubNumber   Int
  githubUrl      String
  title          String
  prNumber       Int?
  prUrl          String?
  /// GitHub login of the developer who merged the PR that closed this issue
  developerLogin String?
  status         QaStatus @default(PENDING)
  createdAt      DateTime @default(now())
  verifiedAt     DateTime?

  tester Tester @relation(fields: [testerId], references: [id], onDelete: Cascade)
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([testerId, repoId, githubNumber, prNumber])
  @@index([testerId, status])
  @@index([repoId, githubNumber])
}
