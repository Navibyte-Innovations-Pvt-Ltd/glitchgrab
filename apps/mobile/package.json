{
  "name": "@glitchgrab/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo start --port 8082",
    "android": "expo run:android",
    "ios": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:ios --port 8082",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean && node scripts/patch-app-delegate.js",
    "dev": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:ios --port 8082",
    "build:android:prod": "bash scripts/set-env.sh production && npx expo prebuild --clean && echo \"sdk.dir=$HOME/Library/Android/sdk\" > android/local.properties && cd android && ./gradlew assembleRelease && cd .. && bash scripts/set-env.sh development && echo '\nAPK ready at: android/app/build/outputs/apk/release/app-release.apk'",
    "build:android:dev": "bash scripts/set-env.sh development && npx expo prebuild --clean && echo \"sdk.dir=$HOME/Library/Android/sdk\" > android/local.properties && cd android && ./gradlew assembleDebug && cd .. && echo '\nAPK ready at: android/app/build/outputs/apk/debug/app-debug.apk'",
    "install:android:prod": "bun run build:android:prod && adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "install:android:dev": "bun run build:android:dev && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "lint": "eslint .",
    "validate": "eslint . && tsc --noEmit"
  },
  "dependencies": {
    "expo": "55.0.25",
    "@expo/vector-icons": "^15.0.2",
    "expo-auth-session": "^55.0.9",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "^55.0.9",
    "expo-file-system": "^55.0.11",
    "expo-router": "~5.0.0",
    "expo-secure-store": "^55.0.9",
    "expo-share-intent": "^6.0.0",
    "expo-splash-screen": "^55.0.0",
    "expo-status-bar": "~55.0.4",
    "expo-media-library": "^16.0.5",
    "expo-web-browser": "^55.0.10",
    "react-native-view-shot": "^5.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "tamagui": "^2.0.0-rc.42",
    "@tamagui/core": "^2.0.0-rc.42",
    "@tamagui/config": "^2.0.0-rc.42",
    "@tamagui/babel-plugin": "^2.0.0-rc.42",
    "@tamagui/toast": "^2.0.0-rc.42",
    "@tamagui/sheet": "^2.0.0-rc.42",
    "@tamagui/portal": "^2.0.0-rc.42",
    "@tanstack/react-query": "^5.83.0",
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0.12",
    "eas-cli": "^18.4.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "expo-mcp": "^0.2.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.32.0"
  },
  "private": true
}
