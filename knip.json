{
  "workspaces": {
    "apps/web": {
      "entry": [
        "next.config.{js,ts,cjs,mjs}",
        "app/**/{page,layout,loading,error,not-found,global-error,template,default}.{ts,tsx}",
        "app/**/route.{ts,tsx}",
        "app/**/actions.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/*.ts"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}"
      ],
      "next": {
        "entry": ["next.config.{js,ts,cjs,mjs}"]
      },
      "ignoreDependencies": [
        "tailwindcss",
        "shadcn",
        "tw-animate-css"
      ]
    },
    "apps/mobile": {
      "entry": [
        "app/**/{_layout,index,page,layout}.{ts,tsx}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}",
        "tamagui.config.ts"
      ],
      "ignore": [
        "src/api.ts",
        "src/screens/**"
      ],
      "ignoreDependencies": [
        "expo-updates",
        "expo-system-ui",
        "eas-cli",
        "react-dom",
        "@tamagui/toast",
        "@tamagui/portal",
        "expo-mcp",
        "expo-clipboard"
      ]
    },
    "packages/sdk-nextjs": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/github",
        "@semantic-release/npm",
        "@semantic-release/release-notes-generator",
        "conventional-changelog-conventionalcommits"
      ]
    },
    "packages/sdk-expo": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@types/react-native"
      ]
    }
  },
  "ignoreDependencies": [
    "@semantic-release/changelog",
    "@semantic-release/git",
    "@semantic-release/npm",
    "@tailwindcss/postcss",
    "tailwindcss",
    "shadcn",
    "tw-animate-css"
  ],
  "ignoreBinaries": ["prisma", "expo", "adb", "semantic-release"],
  "ignoreExportsUsedInFile": true
}
