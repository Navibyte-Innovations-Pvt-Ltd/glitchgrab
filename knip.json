{
  "workspaces": {
    "apps/web": {
      "entry": [
        "next.config.{js,ts,cjs,mjs}",
        "app/**/{page,layout,loading,error,not-found,global-error,template,default}.{ts,tsx}",
        "app/**/route.{ts,tsx}",
        "app/**/actions.{ts,tsx}",
        "app/**/*.test.ts",
        "components/**/*.{ts,tsx}",
        "lib/*.ts"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "app/**/*.test.ts"
      ],
      "next": {
        "entry": ["next.config.{js,ts,cjs,mjs}"]
      },
      "ignore": [
        "components/AppInputFields/**"
      ],
      "ignoreDependencies": [
        "tailwindcss",
        "shadcn",
        "tw-animate-css",
        "eslint-plugin-react-hooks"
      ]
    },
    "apps/mobile": {
      "entry": [
        "app/**/{_layout,index,page,layout}.{ts,tsx}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}",
        "tamagui.config.ts"
      ],
      "ignore": [
        "src/api.ts",
        "src/screens/**"
      ],
      "ignoreDependencies": [
        "expo-updates",
        "expo-system-ui",
        "react-dom",
        "@tamagui/toast",
        "@tamagui/portal",
        "expo-mcp",
        "expo-clipboard",
        "babel-plugin-module-resolver",
        "webidl-conversions"
      ]
    },
    "packages/extension": {
      "entry": ["src/background.ts", "src/content.ts", "src/popup/popup.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/sdk-nextjs": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/github",
        "@semantic-release/npm",
        "@semantic-release/release-notes-generator",
        "conventional-changelog-conventionalcommits"
      ]
    },
    "packages/sdk-expo": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@types/react-native"
      ]
    }
  },
  "ignoreDependencies": [
    "@semantic-release/changelog",
    "@semantic-release/git",
    "@semantic-release/npm",
    "@tailwindcss/postcss",
    "tailwindcss",
    "shadcn",
    "tw-animate-css",
    "axios"
  ],
  "ignoreBinaries": ["prisma", "semantic-release", "wait"],
  "ignore": ["apps/glitchrecord/**"],
  "ignoreExportsUsedInFile": true
}
